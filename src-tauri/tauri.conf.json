{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DMR Desktop",
  "version": "0.1.0",
  "identifier": "com.dmr.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": ["binaries/dmr"],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "DMR Desktop",
    "longDescription": "AI Agent desktop application powered by DMR"
  },
  "app": {
    "windows": [
      {
        "title": "DMR Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
